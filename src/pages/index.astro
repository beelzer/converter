---
import ToolLayout from "../components/ToolLayout.astro";
import { TOOLS } from "../lib/tools";
import { SITE_URL, SITE_NAME } from "../lib/site";

const iconModules = import.meta.glob<string>("../icons/tools/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});
const iconBySlug: Record<string, string> = Object.fromEntries(
  Object.entries(iconModules).map(([path, svg]) => [
    path.split("/").pop()!.replace(/\.svg$/, ""),
    svg,
  ])
);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE_URL,
  description:
    "Free file tools that run entirely in your browser. No uploads, no accounts, no ads.",
};
---

<ToolLayout
  title={`${SITE_NAME} — File tools that run in your browser. No uploads.`}
  description="Free tools to convert and edit PDFs, images, data files, and more. Everything runs in your browser — files never leave your device. No accounts, no uploads, no ads."
  schema={schema}
>
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <h1 class="font-mono text-3xl sm:text-5xl font-semibold leading-tight">
      File tools that run in <span class="text-[var(--color-accent)]">your browser</span>.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--color-fg-muted)] leading-relaxed">
      No uploads. No accounts. No ads. No tracking. Open source.
      Every tool runs entirely on your device — your files never touch a server.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-20" aria-labelledby="tools-heading">
    <h2 id="tools-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-6">
      Tools
    </h2>
    <ul class="grid gap-3 sm:grid-cols-2">
      {TOOLS.map((tool) => (
        <li>
          <a
            href={`/${tool.slug}`}
            class="group block p-5 border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)] hover:no-underline transition-colors"
          >
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-mono text-base font-semibold text-[var(--color-fg)] inline-flex items-center gap-2.5">
                {iconBySlug[tool.slug] && (
                  <span
                    class="tool-icon inline-block shrink-0"
                    aria-hidden="true"
                    set:html={iconBySlug[tool.slug]}
                  />
                )}
                {tool.name}
              </h3>
              {tool.status === "beta" && (
                <span
                  class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-warning)] border border-[var(--color-warning)]/40 px-1.5 py-0.5 rounded-sm"
                  title="Known fidelity gaps — see the page for details"
                >
                  beta
                </span>
              )}
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
              {tool.longBlurb}
            </p>
            <p class="mt-3 font-mono text-xs text-[var(--color-fg-dim)] group-hover:text-[var(--color-accent)] group-hover:underline underline-offset-[0.2em]">
              open →
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>

</ToolLayout>

<style is:global>
  .tool-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }
</style>
