---
import ToolLayout from "../components/ToolLayout.astro";
import PdfToImages from "../components/tools/PdfToImages.tsx";

const title = "PDF to JPG / PNG — convert pages to images in your browser | convert.dcln.me";
const description =
  "Render each page of a PDF as a JPG or PNG image and download them as a ZIP. Runs entirely in your browser — your PDF is never uploaded. Free, open source.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to convert a PDF to JPG or PNG in your browser",
  description:
    "Render PDF pages as JPG or PNG images without uploading anything. Choose a resolution and download single images or a ZIP.",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Choose your PDF",
      text: "Drag a PDF into the converter, or click 'Choose file'. The page count loads instantly.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Pick format and resolution",
      text: "JPG is smaller and lossy. PNG is larger and lossless. Resolution preset determines how many pixels per inch the output images have.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Convert and download",
      text: "Click 'Convert & download'. Your browser renders each page locally and downloads either a single image (if one page) or a ZIP containing all of them.",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Is this really private? Does my PDF get uploaded?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. The rendering runs entirely in your browser using Mozilla's pdf.js library. The PDF is loaded into memory on your device, each page is painted to a local canvas, the canvas is encoded as JPG or PNG, and the result is offered for download. There is no upload — verify it yourself in your browser's network tab.",
      },
    },
    {
      "@type": "Question",
      name: "What's the difference between JPG and PNG output?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "JPG produces smaller files but uses lossy compression — fine details and sharp edges (especially text) can soften slightly. PNG is lossless and supports transparency, but the files can be several times larger. Use PNG when sharp text matters or when you need a transparent background; use JPG when file size matters more than perfection.",
      },
    },
    {
      "@type": "Question",
      name: "Which resolution should I pick?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Screen (96 dpi) is good for viewing on a monitor or sharing online. Print (200 dpi) is a sensible default for most uses. High (300 dpi) matches professional print output but produces much larger files and takes longer to render — only pick it if you'll actually print or zoom in heavily.",
      },
    },
    {
      "@type": "Question",
      name: "Can I extract just a few pages instead of all of them?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Leave the 'Which pages' field blank to render every page, or list specific pages and ranges. '1-3, 5' renders the first three pages plus page 5. If only one page is rendered, you get a single image. If more than one, you get a ZIP.",
      },
    },
    {
      "@type": "Question",
      name: "Why is the conversion slow on large PDFs?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Rendering happens in your browser — your laptop is doing the work that a server normally would. pdf.js (the underlying library) runs in its own background thread, so the page stays responsive, but rendering a 200-page PDF at 300 dpi still takes time. Expect a few seconds per page at high resolution.",
      },
    },
    {
      "@type": "Question",
      name: "Does it work offline?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, after the page has loaded once. The pdf.js library and worker are served from this site, so once they're cached, you can disconnect and keep converting.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Tools",
      item: "https://convert.dcln.me/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "PDF to JPG / PNG",
      item: "https://convert.dcln.me/pdf-to-jpg",
    },
  ],
};
---

<ToolLayout title={title} description={description} schema={[howToSchema, faqSchema, breadcrumbSchema]}>
  <section class="mx-auto max-w-3xl px-6 pt-12 sm:pt-16">
    <p class="font-mono text-xs text-[var(--color-fg-dim)] mb-3 uppercase tracking-widest">
      <a href="/" class="hover:text-[var(--color-fg)]">tools</a>
      <span class="mx-2">/</span>
      <span>pdf-to-jpg</span>
    </p>
    <h1 class="font-mono text-3xl sm:text-4xl font-semibold leading-tight">
      Convert a PDF to JPG or PNG.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Render each page of a PDF as a JPG or PNG image. The whole thing runs on your device — your PDF is never uploaded.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-10" aria-label="PDF to image tool">
    <PdfToImages client:load />
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16" aria-labelledby="how-heading">
    <h2 id="how-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How it works
    </h2>
    <ol class="space-y-4 text-[var(--color-fg-muted)]">
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">01</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Choose your PDF.</strong>
          Drag and drop, or pick a file. The page count loads instantly.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">02</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Format and resolution.</strong>
          JPG (small, lossy) or PNG (lossless). Resolution determines the pixel density of the output.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">03</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Convert &amp; download.</strong>
          Each page is rendered locally. If you asked for one page you get one image; multiple pages arrive as a ZIP.
        </span>
      </li>
    </ol>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16 mb-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      FAQ
    </h2>
    <dl class="space-y-6">
      {faqSchema.mainEntity.map((qa) => (
        <div>
          <dt class="font-mono text-base text-[var(--color-fg)] mb-2">{qa.name}</dt>
          <dd class="text-[var(--color-fg-muted)] leading-relaxed">{qa.acceptedAnswer.text}</dd>
        </div>
      ))}
    </dl>
  </section>
</ToolLayout>
