---
import HubPageLayout from "../components/HubPageLayout.astro";
import ColorHub from "../components/tools/ColorHub.tsx";

const title = "Color tools — HEX, RGB, HSL, OKLCH, CMYK + palette + WCAG | tools.dcln.me";
const description =
  "Convert between HEX, RGB, HSL, OKLCH and CMYK. Generate color harmonies (complementary, analogous, triadic, tetradic, split-complementary, monochromatic). WCAG contrast checker. Everything runs locally.";

const lead =
  "Convert between HEX, RGB, HSL, OKLCH and CMYK. Generate harmonies. Check WCAG contrast. Everything runs locally — no dependencies, no upload, no tracking.";

const faq = [
  {
    q: "Why OKLCH instead of just LCH or LAB?",
    a: "OKLCH (built on Oklab) is perceptually uniform — equal numeric changes correspond to roughly equal perceived changes. It's the format CSS Color Module Level 4 recommends for design-token systems because hue stays consistent across lightness levels, unlike HSL where reds and blues at the same 'lightness' look very different.",
  },
  {
    q: "Are these color values uploaded anywhere?",
    a: "No. All math runs in JavaScript in your browser. There is no server. Open the network tab while you type — you won't see a single request.",
  },
  {
    q: "Why doesn't my CMYK match my printer?",
    a: "CMYK conversions on the web are naive — they use a 'device CMYK' formula that ignores the specific ink set and paper. For prepress work, generate the CMYK you need from a color profile in InDesign / Photoshop, not from a web tool. This tool is fine for rough conversions and reference.",
  },
  {
    q: "What does WCAG AA / AAA mean?",
    a: "AA is the legally common standard (4.5:1 for normal text, 3:1 for large text). AAA is stricter (7:1 / 4.5:1) and harder to hit while keeping a non-grey palette. Large text means 18pt+ regular weight or 14pt+ bold. If you have to pick one, target AA.",
  },
];
---

<HubPageLayout
  title={title}
  description={description}
  slug="color"
  label="Color"
  hubHeading="Color tools."
  lead={lead}
  faq={faq}
>
  <ColorHub client:load />
</HubPageLayout>
