---
import HubPageLayout from "../components/HubPageLayout.astro";
import ImageHub from "../components/tools/ImageHub.tsx";

const title = "Image tools — convert, resize, compress, favicon, EXIF | tools.dcln.me";
const description =
  "All-in-one image toolkit that runs entirely in your browser. Convert between JPG, PNG, WebP, AVIF, HEIC and more. Resize, compress, strip EXIF, build favicons, rasterize SVG. Your images are never uploaded.";

const lead =
  "Convert between formats, resize, compress, strip EXIF, build favicons, or rasterize SVG — all in your browser. Files never leave your device.";

const howToSteps = [
  {
    name: "Pick what you want to do",
    text: "Choose a mode from the tab bar: convert, resize, compress, favicon, strip EXIF, or SVG to raster.",
  },
  {
    name: "Add your image(s)",
    text: "Drag and drop into the drop zone, or click to pick. Some modes accept multiple files.",
  },
  {
    name: "Run and download",
    text: "Configure any options and click the action button. Results download locally — multi-file outputs come as a ZIP.",
  },
];

const howToBlocks = [
  {
    title: "Pick a mode.",
    body: "The tab bar lists six operations: convert, resize, compress, favicon bundle, EXIF strip, SVG to raster.",
  },
  {
    title: "Add your image(s).",
    body: "Drag and drop, or pick. Native browser APIs decode most formats; HEIC and TIFF use lazy-loaded WebAssembly.",
  },
  {
    title: "Configure & download.",
    body: "Adjust the options (output format, quality, dimensions), then run. Multi-file outputs come as a ZIP.",
  },
];

const faq = [
  {
    q: "Are my images really private? Do they get uploaded?",
    a: "No. Every operation runs in your browser. Decoding uses native browser APIs where possible, and WebAssembly (libheif-js, @jsquash/avif) for formats your browser doesn't decode natively. There is no upload — verify it yourself in your browser's network tab.",
  },
  {
    q: "Which formats are supported?",
    a: "Input: JPG, PNG, WebP, AVIF, GIF, BMP, TIFF, HEIC. Output: JPG, PNG, WebP, AVIF. HEIC is decoded via libheif-js (WebAssembly), TIFF via utif2, and AVIF encoding via @jsquash/avif — all lazy-loaded only when needed for the file you drop.",
  },
  {
    q: "Why does compressing a PNG produce a WebP?",
    a: "PNG is lossless — there's no 'quality slider' that meaningfully shrinks a PNG without changing pixels. To get real file-size savings while preserving transparency and a similar pixel pipeline, we re-encode as WebP. JPG, WebP, and AVIF inputs stay in their own format.",
  },
  {
    q: "Does stripping EXIF re-compress the image?",
    a: "No. EXIF stripping uses piexifjs to remove the metadata segment from JPG bytes directly — the actual image pixels are untouched, so there's no quality loss. Only JPGs are supported in this mode; for other formats, convert to JPG first or use the Convert tool, which always re-encodes.",
  },
  {
    q: "Why doesn't HEIC encoding work?",
    a: "Encoding HEIC requires patent-encumbered codecs that aren't available in browser-friendly WASM ports. Decoding works fine, so you can drop an iPhone HEIC and convert it to JPG, PNG, WebP, or AVIF — just not the other way around.",
  },
  {
    q: "Does it work offline?",
    a: "Yes, after the page has loaded once and you've used each mode at least once (which fetches its WASM bundle). After that, the toolkit keeps working without an internet connection.",
  },
];
---

<HubPageLayout
  title={title}
  description={description}
  slug="image"
  label="Image"
  hubHeading="Image tools."
  lead={lead}
  howToName="How to edit images in your browser"
  howToDescription="Convert, resize, compress, strip EXIF, generate a favicon bundle, or rasterize SVG — all locally, without uploading."
  howToSteps={howToSteps}
  howToBlocks={howToBlocks}
  faq={faq}
>
  <ImageHub client:load />
</HubPageLayout>
