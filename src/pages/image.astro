---
import ToolLayout from "../components/ToolLayout.astro";
import ImageHub from "../components/tools/ImageHub.tsx";

const title = "Image tools — convert, resize, compress, favicon, EXIF | convert.dcln.me";
const description =
  "All-in-one image toolkit that runs entirely in your browser. Convert between JPG, PNG, WebP, AVIF, HEIC and more. Resize, compress, strip EXIF, build favicons, rasterize SVG. Your images are never uploaded.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to edit images in your browser",
  description:
    "Convert, resize, compress, strip EXIF, generate a favicon bundle, or rasterize SVG — all locally, without uploading.",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Pick what you want to do",
      text: "Choose a mode from the tab bar: convert, resize, compress, favicon, strip EXIF, or SVG to raster.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Add your image(s)",
      text: "Drag and drop into the drop zone, or click to pick. Some modes accept multiple files.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Run and download",
      text: "Configure any options and click the action button. Results download locally — multi-file outputs come as a ZIP.",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Are my images really private? Do they get uploaded?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Every operation runs in your browser. Decoding uses native browser APIs where possible, and WebAssembly (libheif-js, @jsquash/avif) for formats your browser doesn't decode natively. There is no upload — verify it yourself in your browser's network tab.",
      },
    },
    {
      "@type": "Question",
      name: "Which formats are supported?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Input: JPG, PNG, WebP, AVIF, GIF, BMP, TIFF, HEIC. Output: JPG, PNG, WebP, AVIF. HEIC is decoded via libheif-js (WebAssembly), TIFF via utif2, and AVIF encoding via @jsquash/avif — all lazy-loaded only when needed for the file you drop.",
      },
    },
    {
      "@type": "Question",
      name: "Why does compressing a PNG produce a WebP?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "PNG is lossless — there's no 'quality slider' that meaningfully shrinks a PNG without changing pixels. To get real file-size savings while preserving transparency and a similar pixel pipeline, we re-encode as WebP. JPG, WebP, and AVIF inputs stay in their own format.",
      },
    },
    {
      "@type": "Question",
      name: "Does stripping EXIF re-compress the image?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. EXIF stripping uses piexifjs to remove the metadata segment from JPG bytes directly — the actual image pixels are untouched, so there's no quality loss. Only JPGs are supported in this mode; for other formats, convert to JPG first or use the Convert tool, which always re-encodes.",
      },
    },
    {
      "@type": "Question",
      name: "Why doesn't HEIC encoding work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Encoding HEIC requires patent-encumbered codecs that aren't available in browser-friendly WASM ports. Decoding works fine, so you can drop an iPhone HEIC and convert it to JPG, PNG, WebP, or AVIF — just not the other way around.",
      },
    },
    {
      "@type": "Question",
      name: "Does it work offline?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, after the page has loaded once and you've used each mode at least once (which fetches its WASM bundle). After that, the toolkit keeps working without an internet connection.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Tools",
      item: "https://convert.dcln.me/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Image",
      item: "https://convert.dcln.me/image",
    },
  ],
};
---

<ToolLayout title={title} description={description} schema={[howToSchema, faqSchema, breadcrumbSchema]}>
  <section class="mx-auto max-w-4xl px-6 pt-12 sm:pt-16">
    <p class="font-mono text-xs text-[var(--color-fg-dim)] mb-3 uppercase tracking-widest">
      <a href="/" class="hover:text-[var(--color-fg)]">tools</a>
      <span class="mx-2">/</span>
      <span>image</span>
    </p>
    <h1 class="font-mono text-3xl sm:text-4xl font-semibold leading-tight">
      Image tools.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Convert between formats, resize, compress, strip EXIF, build favicons, or rasterize SVG — all in your browser. Files never leave your device.
    </p>
  </section>

  <section class="mx-auto max-w-4xl px-6 mt-10" aria-label="Image toolkit">
    <ImageHub client:load />
  </section>

  <section class="mx-auto max-w-4xl px-6 mt-16" aria-labelledby="how-heading">
    <h2 id="how-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How it works
    </h2>
    <ol class="space-y-4 text-[var(--color-fg-muted)]">
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">01</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Pick a mode.</strong>
          The tab bar lists six operations: convert, resize, compress, favicon bundle, EXIF strip, SVG to raster.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">02</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Add your image(s).</strong>
          Drag and drop, or pick. Native browser APIs decode most formats; HEIC and TIFF use lazy-loaded WebAssembly.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">03</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Configure &amp; download.</strong>
          Adjust the options (output format, quality, dimensions), then run. Multi-file outputs come as a ZIP.
        </span>
      </li>
    </ol>
  </section>

  <section class="mx-auto max-w-4xl px-6 mt-16 mb-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      FAQ
    </h2>
    <dl class="space-y-6">
      {faqSchema.mainEntity.map((qa) => (
        <div>
          <dt class="font-mono text-base text-[var(--color-fg)] mb-2">{qa.name}</dt>
          <dd class="text-[var(--color-fg-muted)] leading-relaxed">{qa.acceptedAnswer.text}</dd>
        </div>
      ))}
    </dl>
  </section>
</ToolLayout>
