---
import ToolLayout from "../components/ToolLayout.astro";
import PdfSplitter from "../components/tools/PdfSplitter.tsx";

const title = "Split PDF in your browser — extract pages free | convert.dcln.me";
const description =
  "Pull specific pages out of a PDF and download them as a new file. Runs entirely in your browser — your PDF is never uploaded. Free, open source, no signup.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to split a PDF in your browser",
  description:
    "Extract specific pages from a PDF and download them as a new file without uploading anything.",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Choose your PDF",
      text: "Drag a PDF into the splitter, or click 'Choose file'. The page count loads instantly.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Type the pages you want",
      text: "Use ranges and commas: '1-3, 5, 7-' means pages 1 through 3, then page 5, then page 7 to the end.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Extract and download",
      text: "Click 'Extract & download'. Your browser builds the new PDF locally and saves it. The original never leaves your device.",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Is the split really private? Does my PDF get uploaded?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. The entire split runs in your browser using a WebAssembly-based PDF library. Your PDF is loaded into memory on your device, the requested pages are copied into a new document, and the result is offered for download. There is no upload step. Open your browser's network tab — you will see no requests fired when you click extract.",
      },
    },
    {
      "@type": "Question",
      name: "What page range syntax does it accept?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Commas separate items. Each item is either a single page (5), a range (1-3), or an open-ended range (7- means from 7 to the end, -3 means from page 1 to 3). Pages appear in the order you list them, so '5, 1' extracts page 5 followed by page 1.",
      },
    },
    {
      "@type": "Question",
      name: "Can I extract pages into separate files instead of one combined PDF?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Not yet. This first version produces a single combined PDF in the order you list the pages. A future update will add a 'split into multiple files' mode that downloads a ZIP. If you need that today, run the tool once per range.",
      },
    },
    {
      "@type": "Question",
      name: "What is the file size limit?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "There is no server-side limit because there is no server. The practical limit is your browser's available memory — typically a few hundred megabytes on desktop and somewhat less on mobile.",
      },
    },
    {
      "@type": "Question",
      name: "Does it work offline?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, after the page has loaded once. You can disconnect from the internet and the splitter will still work. The conversion makes zero network requests.",
      },
    },
    {
      "@type": "Question",
      name: "Does this support password-protected PDFs?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Not yet. Encrypted PDFs need the password to be unlocked first. You can unlock them in your PDF reader and re-save without a password, then split.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Tools",
      item: "https://convert.dcln.me/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "PDF splitter",
      item: "https://convert.dcln.me/pdf-splitter",
    },
  ],
};
---

<ToolLayout title={title} description={description} schema={[howToSchema, faqSchema, breadcrumbSchema]}>
  <section class="mx-auto max-w-3xl px-6 pt-12 sm:pt-16">
    <p class="font-mono text-xs text-[var(--color-fg-dim)] mb-3 uppercase tracking-widest">
      <a href="/" class="hover:text-[var(--color-fg)]">tools</a>
      <span class="mx-2">/</span>
      <span>pdf-splitter</span>
    </p>
    <h1 class="font-mono text-3xl sm:text-4xl font-semibold leading-tight">
      Split a PDF in your browser.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Pull specific pages out of a PDF and download them as a new file. The whole thing runs on your device — your PDF is never uploaded.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-10" aria-label="PDF splitter tool">
    <PdfSplitter client:load />
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16" aria-labelledby="how-heading">
    <h2 id="how-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How it works
    </h2>
    <ol class="space-y-4 text-[var(--color-fg-muted)]">
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">01</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Choose your PDF.</strong>
          Drag and drop into the box above, or click <span class="font-mono text-sm">Choose file</span>. The page count loads instantly so you know what you&rsquo;re working with.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">02</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Type the pages you want.</strong>
          Use commas and dashes. <span class="font-mono">1-3, 5, 7-</span> means pages 1 to 3, page 5, then page 7 to the end. Pages come out in the order you list them.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">03</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Extract &amp; download.</strong>
          The work runs in a background thread in your browser. When it&rsquo;s done, a new PDF containing exactly the pages you asked for is offered for download.
        </span>
      </li>
    </ol>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16" aria-labelledby="how-it-actually-works">
    <h2 id="how-it-actually-works" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How PDF splitting actually works
    </h2>
    <div class="space-y-4 text-[var(--color-fg-muted)] leading-relaxed">
      <p>
        A PDF is a structured file format: a list of <em>objects</em> (pages, fonts, images, metadata) with a cross-reference table that maps each object to where it lives in the file. Pulling a few pages out of a PDF is not as simple as snipping out bytes — that would leave references pointing at nothing and produce a broken file. A real splitter has to walk the source document, copy the selected page objects (plus the fonts and images they reference) into a new PDF, and emit a fresh cross-reference table.
      </p>
      <p>
        This tool uses <a href="https://pdf-lib.js.org" rel="noopener noreferrer" target="_blank">pdf-lib</a>, an MIT-licensed PDF library that runs in JavaScript. The split happens in a <a href="https://developer.mozilla.org/en-US/docs/Web/API/Web_Workers_API" rel="noopener noreferrer" target="_blank">Web Worker</a> — a separate background thread — so the page stays responsive while pdf-lib does the work.
      </p>
      <p>
        Because the work happens on your machine, two things follow: your PDF is never sent to a server, and the splitter keeps working even if you disconnect from the internet after the page has loaded.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16" aria-labelledby="compare-heading">
    <h2 id="compare-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How this compares
    </h2>
    <div class="border border-[var(--color-border)] rounded-md overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-surface)] font-mono text-xs text-[var(--color-fg-dim)] uppercase tracking-widest">
          <tr>
            <th class="text-left px-4 py-3">&nbsp;</th>
            <th class="text-left px-4 py-3">convert.dcln.me</th>
            <th class="text-left px-4 py-3">Typical online splitter</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--color-border)] text-[var(--color-fg-muted)]">
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Where it runs</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> In your browser</td>
            <td class="px-4 py-3">Server</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Files uploaded</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> Never</td>
            <td class="px-4 py-3">Yes (stored for hours)</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Account needed</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> No</td>
            <td class="px-4 py-3">Often for &gt;N files/day</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Ads</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> None</td>
            <td class="px-4 py-3">Usually</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Works offline</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> Yes (after load)</td>
            <td class="px-4 py-3">No</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-xs text-[var(--color-fg)]">Open source</td>
            <td class="px-4 py-3"><span class="text-[var(--color-accent)]">●</span> MIT, on GitHub</td>
            <td class="px-4 py-3">No</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16 mb-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      FAQ
    </h2>
    <dl class="space-y-6">
      {faqSchema.mainEntity.map((qa) => (
        <div>
          <dt class="font-mono text-base text-[var(--color-fg)] mb-2">{qa.name}</dt>
          <dd class="text-[var(--color-fg-muted)] leading-relaxed">{qa.acceptedAnswer.text}</dd>
        </div>
      ))}
    </dl>
  </section>
</ToolLayout>
