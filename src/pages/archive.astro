---
import HubPageLayout from "../components/HubPageLayout.astro";
import ArchiveHub from "../components/tools/ArchiveHub.tsx";

const title = "Archive tools — create / extract ZIP, TAR, GZIP, RAR | tools.dcln.me";
const description =
  "Create or extract archives entirely in your browser. ZIP, TAR, TAR.GZ, GZIP and RAR (read-only). No upload, no server. Format auto-detected from magic bytes.";

const lead =
  "Create ZIP, TAR, TAR.GZ or GZIP archives, or extract any of those plus RAR — entirely in your browser. Files never touch a server.";

const howToSteps = [
  {
    name: "Pick a mode",
    text: "Choose Create to bundle files together, or Extract to read an existing archive.",
  },
  {
    name: "Drop your files",
    text: "For Create: drop one or more files and pick a format. For Extract: drop a ZIP/TAR/GZIP/RAR — the format is auto-detected.",
  },
  {
    name: "Download",
    text: "Create downloads the bundle. Extract lets you grab individual entries or everything together as a fresh ZIP.",
  },
];

const faq = [
  {
    q: "Why no 7-Zip support?",
    a: "The smallest working in-browser 7z library is a ~1.5 MB WebAssembly build under LGPL, which we can use but would need to disclose. For v1 we'd rather ship without it and add it later if traffic warrants — most archives in the wild are ZIP or RAR, and 7z extraction has good native support in every OS.",
  },
  {
    q: "Why can I extract RAR but not create it?",
    a: "The RAR format is proprietary. WinRAR licenses the decompressor freely (used by node-unrar-js) but not the compressor — there is no open-source RAR writer, anywhere. ZIP and TAR are free and unencumbered, so use one of those for new archives.",
  },
  {
    q: "Are large archives handled well?",
    a: "We load and process the entire archive in memory using fflate, which is fast but caps practically at around 1 GB depending on your browser. For multi-GB tarballs, use a desktop tool. (We may add streaming extraction later if traffic justifies the complexity.)",
  },
  {
    q: "What's the difference between TAR.GZ and ZIP?",
    a: "Both are containers with compression. ZIP compresses each file independently and stores a directory at the end (random-access friendly). TAR.GZ wraps every file in a TAR archive then gzips the whole thing as one stream — usually a little smaller for many small files, but you must decompress the whole thing to read any one entry. Unix tooling defaults to TAR.GZ; Windows defaults to ZIP.",
  },
  {
    q: "Is any of this uploaded?",
    a: "No. fflate is pure JavaScript, RAR extraction uses a WebAssembly build of unrar that runs locally. Open the network tab while you create or extract — nothing leaves your device.",
  },
];
---

<HubPageLayout
  title={title}
  description={description}
  slug="archive"
  label="Archive"
  hubHeading="Archive tools."
  lead={lead}
  howToName="How to create and extract archives in your browser"
  howToSteps={howToSteps}
  faq={faq}
>
  <ArchiveHub client:load />
</HubPageLayout>
