---
import HubPageLayout from "../components/HubPageLayout.astro";
import DataHub from "../components/tools/DataHub.tsx";

const title = "Data tools — convert CSV / JSON / YAML / XML / TOML | tools.dcln.me";
const description =
  "All-in-one data toolkit that runs entirely in your browser. Convert between JSON, YAML, XML, TOML, CSV and TSV. Format, minify, validate, generate TypeScript types. Files never leave your device.";

const lead =
  "Convert between JSON, YAML, XML, TOML, CSV and TSV. Format, minify, validate, or generate TypeScript types — all running locally in your browser.";

const howToSteps = [
  {
    name: "Pick a mode",
    text: "Choose a tab: Convert, Format / Minify, Validate, or TS Types.",
  },
  {
    name: "Paste or drop your data",
    text: "Paste text into the editor, or drop a file. The input format is auto-detected from the file extension.",
  },
  {
    name: "Pick the output format and run",
    text: "Choose the output format, optional minify or indent setting, then click the action button. Copy or download the result.",
  },
];

const howToBlocks = [
  {
    title: "Pick a mode.",
    body: "Four operations: Convert, Format / Minify, Validate, TS Types.",
  },
  {
    title: "Paste or drop a file.",
    body: "The input format is detected from the file extension. You can override it from the dropdown if detection guesses wrong.",
  },
  {
    title: "Copy or download.",
    body: "Output appears below — copy to clipboard, or download as a properly-named file with the right MIME type.",
  },
];

const faq = [
  {
    q: "Does my data get uploaded anywhere?",
    a: "No. All parsing and serialization happens in your browser using small open-source libraries (papaparse, js-yaml, fast-xml-parser, smol-toml). Open the network tab while you convert — you won't see a single byte of your data leave the device.",
  },
  {
    q: "Which formats are supported?",
    a: "JSON, YAML, XML, TOML, CSV and TSV — in both directions. XLSX (Excel) is deferred to a future release because the smallest viable in-browser library is 600KB+ and most XLSX-to-CSV needs are well served by Numbers, LibreOffice, or Excel's own Save As.",
  },
  {
    q: "How accurate are the inferred TypeScript types?",
    a: "The type generator walks your sample and infers structural types — primitives, arrays of T, nested interfaces, and unions including null. It handles the 95% case (REST API responses, config files) well, but it can't know about your discriminators or optional-only fields that don't appear in the sample. Paste a representative example with all the variants and edge cases for best results.",
  },
  {
    q: "Why does TOML conversion sometimes fail?",
    a: "TOML requires a table (object) at the top level — it has no concept of a top-level array. If your source is an array of records, convert via JSON first (your records become an array under a root key) or use CSV / JSON Lines instead.",
  },
  {
    q: "Does CSV preserve numeric types?",
    a: "Yes. The parser uses dynamic typing — values that look like numbers, booleans, or null are converted automatically. If you need to preserve everything as a string (e.g. zip codes with leading zeros), quote them in the source CSV and they'll stay as strings.",
  },
  {
    q: "Does it work offline?",
    a: "Yes, after the page has loaded once. Each format library is small and lazy-loaded only when you actually use it — so the first conversion you run downloads ~50KB, and subsequent ones in the same format are instant.",
  },
];
---

<HubPageLayout
  title={title}
  description={description}
  slug="data"
  label="Data"
  hubHeading="Data tools."
  lead={lead}
  howToName="How to convert and format data files in your browser"
  howToDescription="Convert between JSON, YAML, XML, TOML, CSV and TSV, or format / validate / generate types — all locally."
  howToSteps={howToSteps}
  howToBlocks={howToBlocks}
  faq={faq}
>
  <DataHub client:load />
</HubPageLayout>
