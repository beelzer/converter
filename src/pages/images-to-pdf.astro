---
import ToolLayout from "../components/ToolLayout.astro";
import ImagesToPdf from "../components/tools/ImagesToPdf.tsx";

const title = "Images to PDF — combine JPG, PNG, WebP into one PDF | convert.dcln.me";
const description =
  "Drop JPG, PNG, WebP, GIF or BMP images and combine them into a single PDF. Runs entirely in your browser — your images are never uploaded. Free, open source.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to combine images into a PDF in your browser",
  description:
    "Combine JPG, PNG, WebP, GIF and BMP images into one PDF, in any order, without uploading anything.",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Add your images",
      text: "Drag and drop images into the builder, or click 'Choose images' to pick them. You can mix formats freely.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Put them in order",
      text: "Drag rows to reorder, or use the arrow buttons. The order on screen is the order they will appear in the PDF.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Build and download",
      text: "Click 'Build PDF'. Your browser embeds each image as its own page, sized to that image's dimensions, and offers the resulting PDF for download.",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Are my images really private? Do they get uploaded?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. The whole conversion runs in your browser. Each image is loaded into memory on your device, embedded into a new PDF, and the result is offered for download. There is no upload step. You can verify this by opening your browser's network tab — you will see no requests fire when you click build.",
      },
    },
    {
      "@type": "Question",
      name: "What formats are supported?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "JPG, PNG, WebP, GIF, and BMP. JPG and PNG are embedded directly into the PDF, so quality is identical to the source. WebP, GIF, and BMP are decoded locally by your browser and re-encoded as PNG before embedding (still no upload).",
      },
    },
    {
      "@type": "Question",
      name: "What size are the PDF pages?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Each page is sized to match the source image's pixel dimensions, with no scaling or margins. If you drop a 3000×2000 photo, that's the size of the page. This preserves the image at its original resolution.",
      },
    },
    {
      "@type": "Question",
      name: "Can I add HEIC images from my iPhone?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Not yet. HEIC support needs a dedicated WebAssembly decoder that we're adding to the site as a separate tool. For now, convert HEIC to JPG first — many phones can export as JPG directly, or use a dedicated HEIC converter (one is on this site's roadmap).",
      },
    },
    {
      "@type": "Question",
      name: "Does it work offline?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes, after the page has loaded once. You can disconnect from the internet and the builder still works.",
      },
    },
    {
      "@type": "Question",
      name: "Is there a limit on file size or number of images?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "There's no server-side limit because there is no server. The practical limit is your browser's available memory — typically a few hundred megabytes of image data on desktop, less on mobile.",
      },
    },
  ],
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Tools",
      item: "https://convert.dcln.me/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Images to PDF",
      item: "https://convert.dcln.me/images-to-pdf",
    },
  ],
};
---

<ToolLayout title={title} description={description} schema={[howToSchema, faqSchema, breadcrumbSchema]}>
  <section class="mx-auto max-w-3xl px-6 pt-12 sm:pt-16">
    <p class="font-mono text-xs text-[var(--color-fg-dim)] mb-3 uppercase tracking-widest">
      <a href="/" class="hover:text-[var(--color-fg)]">tools</a>
      <span class="mx-2">/</span>
      <span>images-to-pdf</span>
    </p>
    <h1 class="font-mono text-3xl sm:text-4xl font-semibold leading-tight">
      Combine images into a PDF.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      Drop JPG, PNG, WebP, GIF or BMP files and merge them into a single PDF, one page per image. Runs entirely on your device.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-10" aria-label="Images to PDF tool">
    <ImagesToPdf client:load />
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16" aria-labelledby="how-heading">
    <h2 id="how-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      How it works
    </h2>
    <ol class="space-y-4 text-[var(--color-fg-muted)]">
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">01</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Add your images.</strong>
          Drag and drop, or pick files. Mix JPG, PNG, WebP, GIF and BMP freely — the order is up to you.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">02</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Order the pages.</strong>
          Drag rows or use the arrow buttons. Top of the list becomes the first page.
        </span>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-[var(--color-accent)] text-sm shrink-0 w-8">03</span>
        <span>
          <strong class="text-[var(--color-fg)] font-mono text-base block mb-1">Build &amp; download.</strong>
          Each image becomes a page sized to its native pixel dimensions. JPG and PNG go in untouched. WebP, GIF and BMP are decoded locally and re-encoded as PNG before being embedded.
        </span>
      </li>
    </ol>
  </section>

  <section class="mx-auto max-w-3xl px-6 mt-16 mb-12" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="font-mono text-sm uppercase tracking-widest text-[var(--color-fg-dim)] mb-4">
      FAQ
    </h2>
    <dl class="space-y-6">
      {faqSchema.mainEntity.map((qa) => (
        <div>
          <dt class="font-mono text-base text-[var(--color-fg)] mb-2">{qa.name}</dt>
          <dd class="text-[var(--color-fg-muted)] leading-relaxed">{qa.acceptedAnswer.text}</dd>
        </div>
      ))}
    </dl>
  </section>
</ToolLayout>
