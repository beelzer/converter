---
import HubPageLayout from "../components/HubPageLayout.astro";
import AvHub from "../components/tools/AvHub.tsx";

const title = "Audio/video tools — convert, trim, GIF, extract audio | tools.dcln.me";
const description =
  "All-in-one audio and video toolkit that runs entirely in your browser using WebCodecs. Convert MP4/WebM/MOV/MKV, trim, extract audio, video to GIF, compress, grab frames, merge clips. Nothing is uploaded.";

const lead =
  "Convert between MP4, WebM, MOV and MKV. Trim, compress, extract audio, make GIFs, grab frames, merge clips — all running locally in your browser through WebCodecs. Nothing uploads.";

const howToSteps = [
  {
    name: "Pick a mode",
    text: "Choose a tab: Convert, Trim, Extract audio, Video → GIF, Compress, Frames, or Merge.",
  },
  {
    name: "Drop a video or audio file",
    text: "Drag and drop into the drop zone, or click to pick. Metadata reads instantly — no upload.",
  },
  {
    name: "Set options and run",
    text: "Pick the output container, bitrate, trim range, fps and so on, then click the action button. The file downloads locally when done.",
  },
];

const howToBlocks = [
  {
    title: "Pick a mode.",
    body: "The tab bar lists seven operations: convert, trim, extract audio, video to GIF, compress, frames, merge.",
  },
  {
    title: "Drop a file.",
    body: "Drag and drop, or click. Metadata reads instantly. Powered by mediabunny over WebCodecs — no WASM blob to download, no server round trips.",
  },
  {
    title: "Configure & download.",
    body: "Tune the options for the selected mode, then run. Encoding uses your platform's hardware video encoders where available.",
  },
];

const faq = [
  {
    q: "Does my video get uploaded anywhere?",
    a: "No. Every operation runs in your browser via WebCodecs and mediabunny. Open the network tab while you convert — you won't see a single byte of your file leave the device.",
  },
  {
    q: "Which containers and codecs are supported?",
    a: "Containers in/out: MP4, WebM, MOV, MKV for video; MP3, WAV, AAC, FLAC and Ogg for audio. Video encoding uses H.264 for MP4/MOV and VP9 for WebM/MKV; audio uses AAC, Opus, MP3, FLAC or Vorbis depending on the container. All of these are handled natively by WebCodecs in modern Chromium and Firefox.",
  },
  {
    q: "Why is converting slower than ffmpeg in a terminal?",
    a: "Browsers expose hardware video encoders through WebCodecs, but they cap concurrency and don't allow shared memory across origins without a site-wide isolation flag (COOP/COEP) that breaks third-party embeds. We trade a little speed for keeping the rest of the site fast and ad-network friendly. For typical clips up to a few minutes, conversion completes in seconds.",
  },
  {
    q: "What happens if WebCodecs can't decode my file?",
    a: "You'll get an error explaining the codec isn't supported in your browser. Most real-world MP4/WebM/MOV/MKV files work. Exotic codecs (e.g. ProRes 4444, AV1 in older browsers) may not — try converting them in a desktop tool first, then come back.",
  },
  {
    q: "How does Video → GIF work?",
    a: "Frames are decoded with WebCodecs at the fps you pick, scaled to the target width, then encoded into an animated GIF using gifenc. The encoder runs a fast nearest-neighbor color quantizer per frame — output is great for screen recordings and flat graphics, less ideal for noisy photographic video.",
  },
  {
    q: "Does it work offline?",
    a: "Yes. mediabunny is pure JavaScript with zero dependencies and no WASM blobs — once the page is in the browser cache, the toolkit works without an internet connection.",
  },
];
---

<HubPageLayout
  title={title}
  description={description}
  slug="audio-video"
  label="Audio/Video"
  hubHeading="Audio & video tools."
  lead={lead}
  howToName="How to edit audio and video in your browser"
  howToDescription="Convert, trim, extract audio, make GIFs, compress, grab frames or merge clips — all locally with WebCodecs."
  howToSteps={howToSteps}
  howToBlocks={howToBlocks}
  faq={faq}
>
  <AvHub client:load />
</HubPageLayout>
